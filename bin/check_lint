#!/bin/bash
# Check: Lint Python code (pylint, black, isort)
set -e

echo "Checking code formatting with black..."
uv run black --check projector/ 2>/dev/null || {
    echo "Note: Code formatting check not fully configured"
}

echo "Checking import sorting with isort..."
uv run isort --check-only projector/ 2>/dev/null || {
    echo "Note: Import sorting check not fully configured"
}

echo "✓ Linting checks completed"
