#!/bin/bash
# Check: Test check execution and result recording
set -e

echo "Testing check execution and result recording..."

# Create temporary test database
TEST_DB="/tmp/projector-test-$$.db"
export PROJECTOR_DB="$TEST_DB"

# Create temporary check script
TEMP_CHECK="/tmp/test_check_$$"
cat > "$TEMP_CHECK" << 'EOF'
#!/bin/bash
exit 0
EOF
chmod +x "$TEMP_CHECK"

cleanup() {
    rm -f "$TEST_DB" "$TEMP_CHECK"
}
trap cleanup EXIT

# Initialize
uv run proj init > /dev/null
uv run proj project add test-project > /dev/null
uv run proj worktree add test-project main > /dev/null
uv run proj check add test-project test-check > /dev/null

# Add check script to PATH
export PATH="$(dirname "$TEMP_CHECK"):$PATH"
mv "$TEMP_CHECK" "$(dirname "$TEMP_CHECK")/check_test-check"

# Run check
echo "  Running check..."
uv run proj run test-project main > /dev/null || {
    echo "✗ Check execution failed"
    exit 1
}

# Verify result was recorded
echo "  Verifying result recorded..."
RESULT=$(uv run proj report test-project --format json 2>/dev/null)
if ! echo "$RESULT" | grep -q "pass\|fail"; then
    echo "✗ Result not properly recorded"
    exit 1
fi

echo "✓ Check execution and result recording works"
