#!/bin/bash
# Check: Test complete workflow (init -> configure -> run -> report)
set -e

echo "Testing complete Projector workflow..."

# Create temporary test database
TEST_DB="/tmp/projector-test-$$.db"
export PROJECTOR_DB="$TEST_DB"

cleanup() {
    rm -f "$TEST_DB"
}
trap cleanup EXIT

# Step 1: Initialize
echo "  Step 1: Initialize database"
uv run proj init > /dev/null || {
    echo "✗ Initialization failed"
    exit 1
}

# Step 2: Configure projects
echo "  Step 2: Load YAML configuration"
uv run proj configure --file samples/minimal-examples.yaml > /dev/null || {
    echo "✗ Configuration load failed"
    exit 1
}

# Step 3: List projects
echo "  Step 3: Verify projects"
uv run proj project list > /dev/null || {
    echo "✗ Project listing failed"
    exit 1
}

# Step 4: Generate report
echo "  Step 4: Generate report"
uv run proj report basic-project --format json > /dev/null || {
    echo "✗ Report generation failed"
    exit 1
}

echo "✓ Complete workflow test passed"
