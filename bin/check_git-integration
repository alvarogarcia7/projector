#!/bin/bash
# Check: Test git integration functions
set -e

echo "Testing git integration..."

# Test: We're in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "✗ Not in a git repository"
    exit 1
fi

# Test: Can get current SHA
SHA=$(git rev-parse HEAD 2>/dev/null)
if [ -z "$SHA" ]; then
    echo "✗ Cannot get current SHA"
    exit 1
fi
echo "  ✓ Got current SHA: ${SHA:0:7}"

# Test: Can get commit message
MSG=$(git log -1 --pretty=%B 2>/dev/null)
if [ -z "$MSG" ]; then
    echo "✗ Cannot get commit message"
    exit 1
fi
echo "  ✓ Got commit message"

# Test: Can get author
AUTHOR=$(git log -1 --pretty=%an 2>/dev/null)
if [ -z "$AUTHOR" ]; then
    echo "✗ Cannot get author"
    exit 1
fi
echo "  ✓ Got author: $AUTHOR"

# Test: Can check git status
if ! git status > /dev/null 2>&1; then
    echo "✗ Cannot check git status"
    exit 1
fi
echo "  ✓ Git status check works"

echo "✓ Git integration tests passed"
